    "import cupy as cp\n",
    "\n",
    "def TKEO(video):\n",
    "    F, H, W = video.shape\n",
    "    \n",
    "    # 1. 修正初始化：使用 empty 会包含随机内存垃圾，必须用 zeros 或直接赋值\n",
    "    # 2. 修正计算顺序：直接利用切片计算，不需要先创建 res 再加减\n",
    "    \n",
    "    # 对帧维度 (F) 进行镜像填充，前后各 1 帧\n",
    "    video_padded = cp.pad(video, ((1, 1), (0, 0), (0, 0)), mode=\"reflect\")\n",
    "    \n",
    "    # TKEO 公式: x[n]^2 - x[n-1] * x[n+1]\n",
    "    # video_padded[1:-1] 是原始视频 (F 帧)\n",
    "    # video_padded[:-2]   是前移位 (x[n-1])\n",
    "    # video_padded[2:]    是后移位 (x[n+1])\n",
    "    \n",
    "    res = (video_padded[1:-1]**2) - (video_padded[:-2] * video_padded[2:])\n",
    "    \n",
    "    return res"
   ]
  },
