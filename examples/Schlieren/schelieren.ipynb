    "import cupy as cp\n",
    "\n",
    "def otsu_threshold_cupy(image, float_bins=256):\n",
    "    \"\"\"\n",
    "    使用 CuPy 計算 Otsu 閾值，兼容整數與浮點數陣列。\n",
    "    \n",
    "    參數:\n",
    "        image: CuPy ndarray (可以是 1D, 2D 或 3D 視頻張量)\n",
    "        float_bins: 當輸入為浮點數時，劃分的直方圖區間數量 (預設 256)\n",
    "    返回:\n",
    "        optimal_threshold: 計算出的最佳閾值 (與原陣列 dtype 一致的純量)\n",
    "    \"\"\"\n",
    "    # 1. 展平陣列\n",
    "    img_flat = image.ravel()\n",
    "    \n",
    "    # 2. 判斷資料型態並設定直方圖範圍與 Bins\n",
    "    if image.dtype.kind in 'fc':  # 如果是 float 或 complex\n",
    "        val_min, val_max = cp.nanmin(img_flat), cp.nanmax(img_flat)\n",
    "        bins = float_bins\n",
    "    else:  # 如果是 integer (如 uint8)\n",
    "        val_min, val_max = 0, 255\n",
    "        bins = 256\n",
    "        \n",
    "    # 如果最大值等於最小值，直接返回該值避免除零錯誤\n",
    "    if val_max == val_min:\n",
    "        return val_min\n",
    "\n",
    "    # 3. 建立直方圖\n",
    "    # hist 形狀為 (bins,), bin_edges 形狀為 (bins+1,)\n",
    "    hist, bin_edges = cp.histogram(img_flat, bins=bins, range=(val_min, val_max))\n",
    "    \n",
    "    # 計算區間中心點 (c_k)\n",
    "    bin_centers = (bin_edges[:-1] + bin_edges[1:]) / 2.0\n",
